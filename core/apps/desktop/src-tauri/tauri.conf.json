{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ctx",
  "version": "0.66.0",
  "identifier": "rs.ctx.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "pnpm -C ../web dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ctx"]
      }
    },
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "resources": [
      "bin/*",
      "web/dist/**/*",
      "bundles/manifest.json",
      "bundles/provider_matrix.json",
      "bundles/artifact_identity.json",
      "bundles/runtime_lock.v1.json",
      "bundles/runtime_lock.v2.json",
      "bundles/lucide-settings.svg"
    ],
    "externalBin": ["bin/ctx-daemon", "bin/ctx-mcp"],
    "macOS": {
      "entitlements": "ctx.entitlements",
      "infoPlist": "Info.plist"
    }
  }
}
